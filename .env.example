# ── Anthropic ────────────────────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Email delivery ────────────────────────────────────────────────────────────
EMAIL_TO=you@example.com
EMAIL_FROM=you@example.com

# Gmail SMTP example:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=you@gmail.com
#   SMTP_PASS=your_gmail_app_password   (generate at myaccount.google.com/apppasswords)
#
# SendGrid example:
#   SMTP_HOST=smtp.sendgrid.net
#   SMTP_PORT=587
#   SMTP_USER=apikey
#   SMTP_PASS=your_sendgrid_api_key

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_gmail_address@gmail.com
SMTP_PASS=your_gmail_app_password

# ── YouTube Data API (free — needed once to resolve channel handles) ──────────
# Get a free key: https://console.cloud.google.com → Enable "YouTube Data API v3"
# Run once after adding key: node --env-file=../.env scripts/setup-youtube.js
YOUTUBE_API_KEY=your_youtube_api_key

# ── Podcast Index (free — find builder guest appearances across all podcasts) ──
# Register at: https://api.podcastindex.org
PODCAST_INDEX_API_KEY=your_podcast_index_api_key
PODCAST_INDEX_API_SECRET=your_podcast_index_api_secret

# ── Options ───────────────────────────────────────────────────────────────────
# Daily News lookback (default: 28h — slightly over 24h for safety)
NEWS_LOOKBACK_HOURS=28
# Builder Insight lookback (default: 168h = 7 days)
BUILDER_LOOKBACK_HOURS=168
